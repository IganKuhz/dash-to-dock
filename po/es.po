#: Settings.ui:1064
msgid "Keep the focused application always visible in the dash"
msgstr "Mantener la aplicación activa siempre visible en el dock"

#: Settings.ui:1101
msgid ""
"If disabled, these settings are accessible from gnome-tweak-tool or the "
"extension website."
msgstr ""
"Si se desactiva, estas opciones estarán disponibles en Retoques de GNOME o "
"el sitio web de la extensión."

#: Settings.ui:1118
msgid "Show <i>Applications</i> icon"
msgstr "Mostrar el icono <i>Aplicaciones</i>"

#: Settings.ui:1129
msgid "Move at beginning of the dock"
msgstr "Mover al principio del dock"

#: Settings.ui:1150
msgid "Animate <i>Show Applications</i>"
msgstr "Animar <i>Mostrar aplicaciones</i>"

#: Settings.ui:1171
msgid "Put <i>Show Applications</i> in a dock edge when using Panel mode"
msgstr "Colocar <i>Mostrar aplicaciones</i> en un borde del dock al usar el modo panel"

#: Settings.ui:1211
msgid "Show trash can"
msgstr "Mostrar papelera"

#: Settings.ui:1248
msgid "Show volumes and devices"
msgstr "Mostrar volúmenes y dispositivos"

#: Settings.ui:1258
msgid "Only if mounted"
msgstr "Sólo los montados"

#: Settings.ui:1271
msgid "Include network volumes"
msgstr "Incluir volúmenes de red"

#: Settings.ui:1311
msgid "Isolate volumes, devices and trash windows from file manager"
