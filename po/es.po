#: Settings.ui:1793
msgid "Scroll action"
msgstr "Acción al desplazarse"

#: Settings.ui:1807
msgid "Won't work over icons because 'Fixed icon size' is enabled."
msgstr "No funcionará sobre los iconos porque está activado «Tamaño fijo de los iconos»."

