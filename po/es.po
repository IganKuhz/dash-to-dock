#: Settings.ui:1421
msgid "Hide application tooltip"
msgstr "Ocultar consejo de aplicación"

#: Settings.ui:1458
msgid "Show icons emblems"
msgstr "Mostrar emblemas de iconos"

#: Settings.ui:1471
msgid ""
"When enabled application icons will show notification counters and progress-"
"bars (if Unity API is used)."
msgstr ""
"Cuando está habilitado los iconos de la aplicación mostrarán contadores de "
"notificaciones y barras de progreso (si la API de Unity es usada)"

#: Settings.ui:1486
msgid "Show the number of unread notifications"
msgstr "Mostrar el número de notificaciones sin leer"

#: Settings.ui:1507
msgid "Application-provided counter overrides the notifications counter"
msgstr "El contador proporcionado por la aplicación reemplaza el contador de notificaciones"

#: Settings.ui:1534
msgid "Launchers"
msgstr "Lanzadores"

#: Settings.ui:1574
msgid ""
"Enable Super+(0-9) as shortcuts to activate apps. It can also be used "
"together with Shift and Ctrl."
msgstr ""
"Activar Súper + (0-9) como atajos para activar aplicaciones. Pueden "
"emplearse en conjunto con Mayús y Ctrl."

#: Settings.ui:1593
msgid "Use keyboard shortcuts to activate apps"
msgstr "Usar atajos de teclado para activar aplicaciones"

#: Settings.ui:1669
msgid "Behaviour when clicking on the icon of a running application."
msgstr "Comportamiento al pulsar el icono de una aplicación en ejecución."

#: Settings.ui:1687
msgid "Click action"
